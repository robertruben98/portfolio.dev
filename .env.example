# Claves públicas para servicios disponibles en el cliente
# Copia este archivo a `.env` y reemplaza los valores según tu configuración.

# Web3Forms - Formulario de contacto
PUBLIC_WEB3FORMS_ACCESS_KEY=""

# WakaTime - Estadísticas de tiempo de código
# Obtén tu API key en: https://wakatime.com/settings/api-key
WAKATIME_API_KEY="waka_your_secret_api_key_here"

# Tu username público de WakaTime (visible en tu perfil URL)
# Ejemplo: si tu perfil es wakatime.com/@tu-usuario, pon "tu-usuario"
PUBLIC_WAKATIME_USERNAME="tu-usuario-wakatime"

# GitHub API (opcional) - Aumenta rate limit de 60 a 5000 requests/hora
# Crea un token en: https://github.com/settings/tokens
# Permisos necesarios: public_repo (read-only)
GITHUB_TOKEN="ghp_your_token_here"

# OpenWeather API (opcional) - Para mostrar clima en el Hero
# Obtén tu API key gratis en: https://openweathermap.org/api
OPENWEATHER_API_KEY="your_api_key_here"
